{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/ColumbusLabs/DebtLens/main/schema/debtlens.config.schema.json",
  "title": "DebtLens configuration",
  "description": "Configuration for the DebtLens static-analysis CLI.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Glob patterns to scan."
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Glob patterns to skip."
    },
    "minSeverity": {
      "enum": ["info", "low", "medium", "high"],
      "description": "Lowest severity to report."
    },
    "pack": {
      "anyOf": [
        {
          "enum": [
            "core",
            "react",
            "react-native",
            "next",
            "expo",
            "node",
            "python",
            "python-web",
            "vue",
            "svelte",
            "kotlin",
            "compose",
            "ai-assisted-maintainer",
            "oss-maintainer"
          ]
        },
        {
          "type": "string",
          "pattern": "^\\s*(?:core|react|react-native|next|expo|node|python|python-web|vue|svelte|kotlin|compose|ai-assisted-maintainer|oss-maintainer)(?:\\s*,\\s*(?:core|react|react-native|next|expo|node|python|python-web|vue|svelte|kotlin|compose|ai-assisted-maintainer|oss-maintainer))*\\s*$"
        }
      ],
      "description": "Built-in rule pack preset, or a comma-separated list of presets. Explicit rules override the pack."
    },
    "rules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "anyOf": [
          {
            "enum": [
              "large-component",
              "large-function",
              "state-sprawl",
              "effect-complexity",
              "hook-dependency-smell",
              "context-provider-sprawl",
              "rn-host-forwarding",
              "server-client-boundary",
              "route-handler-size",
              "data-loader-sprawl",
              "handler-depth",
              "route-sprawl",
              "duplicate-logic",
              "test-duplication",
              "duplicated-literal",
              "import-cycle",
              "complex-control-flow",
              "config-drift",
              "dead-abstraction",
              "prop-drilling",
              "todo-comment",
              "naming-drift",
              "barrel-file",
              "weak-test-boundary",
              "api-surface-sprawl",
              "story-only-component",
              "python-todo-comment",
              "python-large-function",
              "python-complex-control-flow",
              "python-duplicate-logic",
              "python-dead-abstraction",
              "python-route-sprawl",
              "vue-todo-comment",
              "vue-large-script",
              "vue-duplicate-logic",
              "svelte-todo-comment",
              "svelte-large-script",
              "svelte-duplicate-logic",
              "kotlin-todo-comment",
              "kotlin-large-function",
              "kotlin-duplicate-logic",
              "kotlin-dead-abstraction",
              "compose-large-composable",
              "compose-state-hoisting"
            ]
          },
          {
            "type": "string",
            "description": "A plugin-provided rule id."
          }
        ]
      },
      "description": "Rule ids to run. Omit to run all rules. May include plugin rule ids when plugins are configured."
    },
    "pluginApiVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Plugin API version this config targets; must match the DebtLens runtime version."
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths to local ESM plugin modules, resolved relative to the config file directory."
    },
    "maxFiles": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum number of files to scan."
    },
    "respectGitignore": {
      "type": "boolean",
      "description": "When true, skip files ignored by git in addition to configured exclude globs."
    },
    "thresholds": {
      "type": "object",
      "description": "Per-rule numeric threshold overrides.",
      "properties": {
        "large-component.maxLines": {
          "type": "number"
        },
        "large-component.maxBranches": {
          "type": "number"
        },
        "large-component.maxHooks": {
          "type": "number"
        },
        "large-function.maxLines": {
          "type": "number"
        },
        "large-function.maxBranches": {
          "type": "number"
        },
        "state-sprawl.maxStatefulHooks": {
          "type": "number"
        },
        "effect-complexity.maxLines": {
          "type": "number"
        },
        "effect-complexity.maxDependencies": {
          "type": "number"
        },
        "context-provider-sprawl.maxProviders": {
          "type": "number"
        },
        "rn-host-forwarding.maxForwardedProps": {
          "type": "number"
        },
        "rn-host-forwarding.maxHostTargets": {
          "type": "number"
        },
        "route-handler-size.maxLines": {
          "type": "number"
        },
        "route-handler-size.maxBranches": {
          "type": "number"
        },
        "route-handler-size.maxAwaits": {
          "type": "number"
        },
        "data-loader-sprawl.maxAwaits": {
          "type": "number"
        },
        "data-loader-sprawl.maxFetches": {
          "type": "number"
        },
        "data-loader-sprawl.maxBranches": {
          "type": "number"
        },
        "data-loader-sprawl.maxLines": {
          "type": "number"
        },
        "handler-depth.maxDepth": {
          "type": "number"
        },
        "handler-depth.maxMiddleware": {
          "type": "number"
        },
        "route-sprawl.maxRoutes": {
          "type": "number"
        },
        "python-route-sprawl.maxRoutes": {
          "type": "number"
        },
        "vue-large-script.maxLines": {
          "type": "number"
        },
        "vue-large-script.maxFunctionLines": {
          "type": "number"
        },
        "vue-large-script.maxBranches": {
          "type": "number"
        },
        "svelte-large-script.maxLines": {
          "type": "number"
        },
        "svelte-large-script.maxFunctionLines": {
          "type": "number"
        },
        "svelte-large-script.maxBranches": {
          "type": "number"
        },
        "duplicate-logic.minSimilarity": {
          "type": "number"
        },
        "duplicate-logic.minLines": {
          "type": "number"
        },
        "duplicate-logic.maxSnippets": {
          "type": "number"
        },
        "test-duplication.minSimilarity": {
          "type": "number"
        },
        "test-duplication.minStructuralSimilarity": {
          "type": "number"
        },
        "test-duplication.minLines": {
          "type": "number"
        },
        "duplicated-literal.minLength": {
          "type": "number"
        },
        "duplicated-literal.minCount": {
          "type": "number"
        },
        "dead-abstraction.maxWrapperLines": {
          "type": "number"
        },
        "prop-drilling.maxForwardedProps": {
          "type": "number"
        },
        "naming-drift.minVariants": {
          "type": "number"
        },
        "duplicate-logic.minStructuralSimilarity": {
          "type": "number"
        },
        "barrel-file.maxReExports": {
          "type": "number"
        },
        "weak-test-boundary.allowTypeOnly": {
          "type": "number"
        },
        "api-surface-sprawl.maxExports": {
          "type": "number"
        },
        "import-cycle.minCycleSize": {
          "type": "number"
        },
        "import-cycle.allowTypeOnly": {
          "type": "number"
        },
        "complex-control-flow.maxComplexity": {
          "type": "number"
        },
        "complex-control-flow.maxDepth": {
          "type": "number"
        },
        "config-drift.maxConfigFiles": {
          "type": "number"
        },
        "compose-large-composable.maxLines": {
          "type": "number"
        },
        "compose-large-composable.maxBranches": {
          "type": "number"
        },
        "compose-large-composable.maxLocalState": {
          "type": "number"
        },
        "compose-state-hoisting.maxLocalState": {
          "type": "number"
        }
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "vocabulary": {
      "type": "object",
      "description": "Naming-drift concept groups (concept id -> competing terms).",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "ruleSeverities": {
      "type": "object",
      "description": "Rule id -> severity reported for that rule's issues, replacing the detector's choice. May include plugin rule ids.",
      "properties": {
        "large-component": {
          "enum": ["info", "low", "medium", "high"]
        },
        "large-function": {
          "enum": ["info", "low", "medium", "high"]
        },
        "state-sprawl": {
          "enum": ["info", "low", "medium", "high"]
        },
        "effect-complexity": {
          "enum": ["info", "low", "medium", "high"]
        },
        "hook-dependency-smell": {
          "enum": ["info", "low", "medium", "high"]
        },
        "context-provider-sprawl": {
          "enum": ["info", "low", "medium", "high"]
        },
        "rn-host-forwarding": {
          "enum": ["info", "low", "medium", "high"]
        },
        "server-client-boundary": {
          "enum": ["info", "low", "medium", "high"]
        },
        "route-handler-size": {
          "enum": ["info", "low", "medium", "high"]
        },
        "data-loader-sprawl": {
          "enum": ["info", "low", "medium", "high"]
        },
        "handler-depth": {
          "enum": ["info", "low", "medium", "high"]
        },
        "route-sprawl": {
          "enum": ["info", "low", "medium", "high"]
        },
        "duplicate-logic": {
          "enum": ["info", "low", "medium", "high"]
        },
        "test-duplication": {
          "enum": ["info", "low", "medium", "high"]
        },
        "duplicated-literal": {
          "enum": ["info", "low", "medium", "high"]
        },
        "import-cycle": {
          "enum": ["info", "low", "medium", "high"]
        },
        "complex-control-flow": {
          "enum": ["info", "low", "medium", "high"]
        },
        "config-drift": {
          "enum": ["info", "low", "medium", "high"]
        },
        "dead-abstraction": {
          "enum": ["info", "low", "medium", "high"]
        },
        "prop-drilling": {
          "enum": ["info", "low", "medium", "high"]
        },
        "todo-comment": {
          "enum": ["info", "low", "medium", "high"]
        },
        "naming-drift": {
          "enum": ["info", "low", "medium", "high"]
        },
        "barrel-file": {
          "enum": ["info", "low", "medium", "high"]
