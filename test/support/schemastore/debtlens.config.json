        "api-surface-sprawl": {
          "enum": ["info", "low", "medium", "high"]
        },
        "story-only-component": {
          "enum": ["info", "low", "medium", "high"]
        },
        "python-todo-comment": {
          "enum": ["info", "low", "medium", "high"]
        },
        "python-large-function": {
          "enum": ["info", "low", "medium", "high"]
        },
        "python-complex-control-flow": {
          "enum": ["info", "low", "medium", "high"]
        },
        "python-duplicate-logic": {
          "enum": ["info", "low", "medium", "high"]
        },
        "python-dead-abstraction": {
          "enum": ["info", "low", "medium", "high"]
        },
        "python-route-sprawl": {
          "enum": ["info", "low", "medium", "high"]
        },
        "vue-todo-comment": {
          "enum": ["info", "low", "medium", "high"]
        },
        "vue-large-script": {
          "enum": ["info", "low", "medium", "high"]
        },
        "vue-duplicate-logic": {
          "enum": ["info", "low", "medium", "high"]
        },
        "svelte-todo-comment": {
          "enum": ["info", "low", "medium", "high"]
        },
        "svelte-large-script": {
          "enum": ["info", "low", "medium", "high"]
        },
        "svelte-duplicate-logic": {
          "enum": ["info", "low", "medium", "high"]
        },
        "kotlin-todo-comment": {
          "enum": ["info", "low", "medium", "high"]
        },
        "kotlin-large-function": {
          "enum": ["info", "low", "medium", "high"]
        },
        "kotlin-duplicate-logic": {
          "enum": ["info", "low", "medium", "high"]
        },
        "kotlin-dead-abstraction": {
          "enum": ["info", "low", "medium", "high"]
        },
        "compose-large-composable": {
          "enum": ["info", "low", "medium", "high"]
        },
        "compose-state-hoisting": {
          "enum": ["info", "low", "medium", "high"]
        }
      },
      "additionalProperties": {
        "enum": ["info", "low", "medium", "high"]
      }
    },
    "ruleConfidenceFloors": {
      "type": "object",
      "description": "Rule id -> minimum confidence (0-1); issues from that rule below the floor are not reported. May include plugin rule ids.",
      "properties": {
        "large-component": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "large-function": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "state-sprawl": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "effect-complexity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "hook-dependency-smell": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "context-provider-sprawl": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rn-host-forwarding": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "server-client-boundary": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "route-handler-size": {
          "type": "number",
