          "minimum": 0,
          "maximum": 1
        },
        "python-route-sprawl": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "vue-todo-comment": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "vue-large-script": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "vue-duplicate-logic": {
